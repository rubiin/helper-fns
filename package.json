{
  "name": "helper-fns",
  "version": "2.9.3",
  "description": "Some common utilities functions for everyday backend usage with zero dependencies",
  "homepage": "https://github.com/rubiin/helper-fns#readme",
  "bugs": "https://github.com/rubiin/helper-fns/issues",
  "license": "MIT",
  "author": "Rubin Bhandari <roobin.bhandari@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubiin/helper-fns.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "docs": "npx typedoc src/index.ts --out docs",
    "build": "unbuild",
    "lint": "oxlint --ignore-pattern",
    "lint:fix": "oxlint --fix",
    "prepublish": "npm run build",
    "prerelease": "npm run build",
    "release": "bumpp && clean-publish",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt"
  },
  "devDependencies": {
    "@rubiin/tsconfig": "^2.0.1",
    "@types/node": "^24.12.2",
    "bumpp": "^11.0.1",
    "clean-publish": "^6.0.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^3.2.4"
  },
  "vitest": {
    "globals": true,
    "testTimeout": 30000,
    "include": [
      "test/**/*.test.ts"
    ],
    "environment": "node",
    "coverage": {
      "reportsDirectory": "./coverage",
      "reporter": [
        "text",
        "html"
      ]
    }
  }
}

{
  "name": "helper-fns",
  "type": "module",
  "version": "2.9.3",
  "description": "Some common utilities functions for everyday backend usage with zero dependencies",
  "author": "Rubin Bhandari <roobin.bhandari@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/rubiin/helper-fns#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubiin/helper-fns.git"
  },
  "bugs": "https://github.com/rubiin/helper-fns/issues",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "docs": "npx typedoc src/index.ts --out docs",
    "build": "unbuild",
    "lint": "oxlint --ignore-pattern",
    "lint:fix": "oxlint --fix",
    "prepublish": "npm run build",
    "prerelease": "npm run build",
    "release": "bumpp && clean-publish",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.15",
    "bumpp": "^10.2.3",
    "clean-publish": "^6.0.5",
    "jest": "29.7.0",
    "ts-jest": "29.1.2",
    "typescript": "^5.9.2",
    "unbuild": "^3.6.1",
    "oxlint": "^1.15.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "testTimeout": 30000,
    "rootDir": "test",
    "testRegex": ".test.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageReporters": [
      "text",
      "html"
    ]
  }
}